        <mxCell id="svc-secrets" value="Secret Manager&#xa;(source API keys)" style="sketch=0;outlineConnect=0;fontColor=#3B3B3B;gradientColor=none;fillColor=#ffffff;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=0;labelBackgroundColor=#ffffff;shape=mxgraph.gcp2.secret_manager;" vertex="1" parent="1">
          <mxGeometry x="1460" y="740" width="40" height="36" as="geometry" />
        </mxCell>
        <mxCell id="svc-vertex" value="Vertex AI&#xa;(Agent Builder + Gemini)" style="sketch=0;outlineConnect=0;fontColor=#3B3B3B;gradientColor=none;fillColor=#ffffff;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=1;labelBackgroundColor=#ffffff;shape=mxgraph.gcp2.vertex_ai;" vertex="1" parent="1">
          <mxGeometry x="1660" y="740" width="40" height="36" as="geometry" />
        </mxCell>

        <mxCell id="svc-looker" value="Looker&#xa;(dashboards &amp; reports)" style="sketch=0;outlineConnect=0;fontColor=#3B3B3B;gradientColor=none;fillColor=#ffffff;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=1;labelBackgroundColor=#ffffff;shape=mxgraph.gcp2.looker;" vertex="1" parent="1">
          <mxGeometry x="1260" y="880" width="40" height="36" as="geometry" />
        </mxCell>
        <mxCell id="svc-dataplex" value="Dataplex&#xa;(governance / lineage)" style="sketch=0;outlineConnect=0;fontColor=#3B3B3B;gradientColor=none;fillColor=#ffffff;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=0;labelBackgroundColor=#ffffff;shape=mxgraph.gcp2.dataplex;" vertex="1" parent="1">
          <mxGeometry x="1460" y="880" width="40" height="36" as="geometry" />
        </mxCell>
        <mxCell id="svc-kms" value="Cloud KMS&#xa;(CMEK keys)" style="sketch=0;outlineConnect=0;fontColor=#3B3B3B;gradientColor=none;fillColor=#ffffff;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=0;labelBackgroundColor=#ffffff;shape=mxgraph.gcp2.key_management_service;" vertex="1" parent="1">
          <mxGeometry x="1660" y="880" width="40" height="36" as="geometry" />
        </mxCell>

        <!-- Note inside VPC-SC -->
        <mxCell id="vpcsc-note" value="All services accessed via Private Google Access /&#xa;PSC endpoints — traffic never leaves Google backbone.&#xa;VPC-SC prevents data exfil even with stolen creds." style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontStyle=2;fontColor=#D93025" vertex="1" parent="1">
          <mxGeometry x="1220" y="1020" width="590" height="60" as="geometry" />
        </mxCell>

        <!-- ============== GLOBAL / PROJECT-WIDE SERVICES ============== -->
        <mxCell id="global-lane" value="Project-wide services (Identity, Observability, Security)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F1F3F4;strokeColor=#5F6368;strokeWidth=1;verticalAlign=top;fontStyle=1;fontSize=11;spacingTop=5;fontColor=#5F6368;dashed=1" vertex="1" parent="1">
          <mxGeometry x="70" y="1140" width="1760" height="160" as="geometry" />
        </mxCell>

        <mxCell id="g-iam" value="Cloud IAM" style="sketch=0;outlineConnect=0;fontColor=#3B3B3B;gradientColor=none;fillColor=#ffffff;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=0;labelBackgroundColor=#F1F3F4;shape=mxgraph.gcp2.identity_and_access_management;" vertex="1" parent="1">
          <mxGeometry x="160" y="1180" width="40" height="36" as="geometry" />
        </mxCell>
        <mxCell id="g-logging" value="Cloud Logging" style="sketch=0;outlineConnect=0;fontColor=#3B3B3B;gradientColor=none;fillColor=#ffffff;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=0;labelBackgroundColor=#F1F3F4;shape=mxgraph.gcp2.cloud_logging;" vertex="1" parent="1">
          <mxGeometry x="380" y="1180" width="40" height="36" as="geometry" />
        </mxCell>
        <mxCell id="g-mon" value="Cloud Monitoring" style="sketch=0;outlineConnect=0;fontColor=#3B3B3B;gradientColor=none;fillColor=#ffffff;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=0;labelBackgroundColor=#F1F3F4;shape=mxgraph.gcp2.cloud_monitoring;" vertex="1" parent="1">
          <mxGeometry x="600" y="1180" width="40" height="36" as="geometry" />
        </mxCell>
        <mxCell id="g-scc" value="Security Command Center" style="sketch=0;outlineConnect=0;fontColor=#3B3B3B;gradientColor=none;fillColor=#ffffff;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=0;labelBackgroundColor=#F1F3F4;shape=mxgraph.gcp2.security_command_center;" vertex="1" parent="1">
          <mxGeometry x="830" y="1180" width="40" height="36" as="geometry" />
        </mxCell>
        <mxCell id="g-dns" value="Cloud DNS" style="sketch=0;outlineConnect=0;fontColor=#3B3B3B;gradientColor=none;fillColor=#ffffff;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=0;labelBackgroundColor=#F1F3F4;shape=mxgraph.gcp2.cloud_dns;" vertex="1" parent="1">
          <mxGeometry x="1080" y="1180" width="40" height="36" as="geometry" />
        </mxCell>
        <mxCell id="g-build" value="Cloud Build&#xa;(CI/CD)" style="sketch=0;outlineConnect=0;fontColor=#3B3B3B;gradientColor=none;fillColor=#ffffff;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=0;labelBackgroundColor=#F1F3F4;shape=mxgraph.gcp2.cloud_build;" vertex="1" parent="1">
          <mxGeometry x="1300" y="1180" width="40" height="36" as="geometry" />
        </mxCell>
        <mxCell id="g-armor-repo" value="Artifact Registry" style="sketch=0;outlineConnect=0;fontColor=#3B3B3B;gradientColor=none;fillColor=#ffffff;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=0;labelBackgroundColor=#F1F3F4;shape=mxgraph.gcp2.artifact_registry;" vertex="1" parent="1">
          <mxGeometry x="1540" y="1180" width="40" height="36" as="geometry" />
        </mxCell>
        <mxCell id="g-note" value="These services attach globally to the project and are enforced regardless of subnet or region. IAM gates all API calls; Logging &amp; Monitoring capture every flow; SCC posture-checks the whole environment." style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontStyle=2;fontColor=#5F6368" vertex="1" parent="1">
          <mxGeometry x="90" y="1250" width="1720" height="40" as="geometry" />
        </mxCell>

        <!-- ================= EDGES (NETWORK FLOWS) ================= -->

        <!-- External sources → Cloud NAT → Pullers (egress path) -->
        <mxCell id="ed1" value="HTTPS pull" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;startArrow=classic;strokeColor=#D93025;strokeWidth=1.5;fontSize=10;fontStyle=2;" edge="1" parent="1" source="ext-sources-box" target="cloud-nat">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ed2" value="NAT egress" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;strokeColor=#D93025;strokeWidth=1.5;fontSize=10;" edge="1" parent="1" source="cloud-nat" target="r-pullers">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Users → Armor → LB → IAP → App Engine (ingress path) -->
        <mxCell id="ed3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;strokeColor=#D93025;strokeWidth=1.5;" edge="1" parent="1" source="ext-users-box" target="cloud-armor">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ed4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;strokeColor=#D93025;strokeWidth=1.5;" edge="1" parent="1" source="cloud-armor" target="ext-lb">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ed5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;strokeColor=#D93025;strokeWidth=1.5;" edge="1" parent="1" source="ext-lb" target="iap">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ed6" value="auth" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;strokeColor=#D93025;strokeWidth=1.5;fontSize=10;" edge="1" parent="1" source="iap" target="r-app">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Internal flows: scheduler → pullers → pubsub (via PSC) -->
        <mxCell id="ed7" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;strokeColor=#188038;strokeWidth=1.5;" edge="1" parent="1" source="r-scheduler" target="r-pullers">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Pullers → VPC Connector → PSC → Pub/Sub -->
        <mxCell id="ed8" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;strokeColor=#188038;strokeWidth=1.5;" edge="1" parent="1" source="r-pullers" target="r-conn-ingest">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ed9" value="publish (via PSC)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;strokeColor=#8430CE;strokeWidth=1.5;fontSize=10;" edge="1" parent="1" source="r-conn-ingest" target="svc-pubsub">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Secrets → Pullers -->
        <mxCell id="ed10" value="creds (PSC)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;strokeColor=#8430CE;strokeWidth=1.5;dashed=1;fontSize=10;" edge="1" parent="1" source="svc-secrets" target="r-pullers">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Pub/Sub → Dataflow -->
        <mxCell id="ed11" value="subscribe (PSC)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;strokeColor=#8430CE;strokeWidth=1.5;fontSize=10;" edge="1" parent="1" source="svc-pubsub" target="r-dataflow">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Dataflow → Matching → BQ/Spanner/GCS -->
        <mxCell id="ed12" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;strokeColor=#F9AB00;strokeWidth=1.5;" edge="1" parent="1" source="r-dataflow" target="r-match">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ed13" value="raw rows (PSC)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;strokeColor=#8430CE;strokeWidth=1.5;fontSize=10;" edge="1" parent="1" source="r-conn-process" target="svc-bq">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ed14" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;strokeColor=#F9AB00;strokeWidth=1.5;" edge="1" parent="1" source="r-dataflow" target="r-conn-process">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ed15" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;strokeColor=#F9AB00;strokeWidth=1.5;" edge="1" parent="1" source="r-match" target="r-conn-process">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ed16" value="matched rows (PSC)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;strokeColor=#8430CE;strokeWidth=1.5;fontSize=10;" edge="1" parent="1" source="r-conn-process" target="svc-spanner">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ed17" value="archive (PSC)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;strokeColor=#8430CE;strokeWidth=1.5;dashed=1;fontSize=10;" edge="1" parent="1" source="r-conn-process" target="svc-gcs">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- App / API → Vertex / Looker -->
        <mxCell id="ed18" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;strokeColor=#D93025;strokeWidth=1.5;" edge="1" parent="1" source="r-apigw" target="r-app">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ed19" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;strokeColor=#D93025;strokeWidth=1.5;" edge="1" parent="1" source="r-app" target="r-internal-lb">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ed20" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;strokeColor=#D93025;strokeWidth=1.5;" edge="1" parent="1" source="r-internal-lb" target="r-conn-app">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ed21" value="NL query (PSC)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;strokeColor=#8430CE;strokeWidth=1.5;fontSize=10;" edge="1" parent="1" source="r-conn-app" target="svc-vertex">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ed22" value="SQL (PSC)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;strokeColor=#8430CE;strokeWidth=1.5;fontSize=10;" edge="1" parent="1" source="r-conn-app" target="svc-bq">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ed23" value="lookups (PSC)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;strokeColor=#8430CE;strokeWidth=1.5;fontSize=10;" edge="1" parent="1" source="r-conn-app" target="svc-spanner">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Vertex AI queries BQ/Spanner -->
        <mxCell id="ed24" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;strokeColor=#8430CE;strokeWidth=1.5;dashed=1;" edge="1" parent="1" source="svc-vertex" target="svc-bq">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ed25" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;strokeColor=#8430CE;strokeWidth=1.5;dashed=1;" edge="1" parent="1" source="svc-vertex" target="svc-spanner">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Looker reads BQ -->
        <mxCell id="ed26" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;strokeColor=#8430CE;strokeWidth=1.5;" edge="1" parent="1" source="svc-looker" target="svc-bq">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ================= SCALE-OUT LEGEND ================= -->
        <mxCell id="legend" value="Network &amp; Scale-out Considerations" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#1A73E8;strokeWidth=2;verticalAlign=top;fontStyle=1;fontSize=13;spacingTop=8;fontColor=#1A73E8" vertex="1" parent="1">
          <mxGeometry x="40" y="1340" width="1820" height="140" as="geometry" />
        </mxCell>
        <mxCell id="leg-n1" value="🌐 &lt;b&gt;VPC topology&lt;/b&gt; — custom-mode VPC, /16 per region. Subnets sized for burst: ingest /24, process /24, app /24. Secondary ranges reserved for GKE pods/services if workloads move there." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="60" y="1375" width="880" height="22" as="geometry" />
        </mxCell>
        <mxCell id="leg-n2" value="🔒 &lt;b&gt;Private path only&lt;/b&gt; — Serverless VPC Connectors + PSC endpoints for all Google APIs. No public IPs on workloads. VPC-SC perimeter prevents BQ/GCS/Spanner exfil." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="60" y="1397" width="880" height="22" as="geometry" />
        </mxCell>
        <mxCell id="leg-n3" value="⬇ &lt;b&gt;Egress to external APIs&lt;/b&gt; — all source-API calls leave through Cloud NAT with allow-listed egress; Cloud Router advertises routes. Optional Cloud VPN/Interconnect for private sources (CMDB, AD)." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="60" y="1419" width="880" height="22" as="geometry" />
        </mxCell>
        <mxCell id="leg-n4" value="⬆ &lt;b&gt;User ingress&lt;/b&gt; — External HTTPS LB → Cloud Armor (WAF, DDoS) → Identity-Aware Proxy (SSO, context-aware) → App Engine. No direct public access to data layers." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="60" y="1441" width="880" height="22" as="geometry" />
        </mxCell>
        <mxCell id="leg-n5" value="📈 &lt;b&gt;Horizontal scale&lt;/b&gt; — Cloud Run auto-scales 0→N per source; Dataflow workers scale with Pub/Sub backlog; BigQuery slots scale on demand; Spanner nodes added independently." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="960" y="1375" width="880" height="22" as="geometry" />
        </mxCell>
        <mxCell id="leg-n6" value="🌍 &lt;b&gt;Multi-region&lt;/b&gt; — primary europe-west2, DR europe-west1. Spanner multi-region config = synchronous replication. BQ multi-region dataset. Global HTTPS LB handles failover via health-checks." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="960" y="1397" width="880" height="22" as="geometry" />
        </mxCell>
        <mxCell id="leg-n7" value="➕ &lt;b&gt;Onboard a new source&lt;/b&gt; — add a Cloud Run service in ingest-snet + a Pub/Sub topic. Firewall rule &amp; NAT egress allow-list updated. No VPC changes." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="960" y="1419" width="880" height="22" as="geometry" />
        </mxCell>
        <mxCell id="leg-n8" value="🔐 &lt;b&gt;Hardening checklist&lt;/b&gt; — IAM least-privilege, CMEK via KMS on BQ/Spanner/GCS, audit logs to dedicated project, SCC Premium posture monitoring, Binary Authorization on Cloud Run/GKE." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11;fontStyle=2" vertex="1" parent="1">
          <mxGeometry x="960" y="1441" width="880" height="22" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
