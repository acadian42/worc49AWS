        <mxCell id="svc-gcs" value="Cloud Storage&#xa;(historic archive,&#xa;Nearline → Coldline)" style="sketch=0;outlineConnect=0;fontColor=#3B3B3B;gradientColor=none;fillColor=#ffffff;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=1;labelBackgroundColor=#ffffff;shape=mxgraph.gcp2.cloud_storage;" vertex="1" parent="1">
          <mxGeometry x="1660" y="600" width="40" height="36" as="geometry" />
        </mxCell>

        <mxCell id="svc-pubsub" value="Pub/Sub&#xa;(topic per source)" style="sketch=0;outlineConnect=0;fontColor=#3B3B3B;gradientColor=none;fillColor=#ffffff;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=0;labelBackgroundColor=#ffffff;shape=mxgraph.gcp2.pub_sub;" vertex="1" parent="1">
