          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1584" y="600" />
              <mxPoint x="1324" y="600" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ============ NACLs ============ -->

        <!-- Public NACL -->
        <mxCell id="public-nacl" value="NACL: malware-lab-dev-public-nacl&#xa;Egress: 443,80,53 + ephemeral&#xa;Ingress: from 10.200.10.0/24 + ephemeral&#xa;+ Dynamic blocked_cidrs deny rules" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=9;align=left;verticalAlign=top;spacingLeft=5;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="630" y="320" width="250" height="80" as="geometry" />
