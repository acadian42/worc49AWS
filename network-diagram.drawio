          <mxGeometry x="80" y="1060" width="350" height="120" as="geometry" />
        </mxCell>

        <mxCell id="flow-legend-text" value="&#xa;&#x2022; Green lines — S3/storage traffic (via VPCE)&#xa;&#x2022; Yellow lines — NAT egress traffic (HTTPS/HTTP/DNS)&#xa;&#x2022; Purple lines — VPC endpoint &amp; network control&#xa;&#x2022; Pink lines — SSM session &amp; monitoring&#xa;&#x2022; Red dashed — security/encryption&#xa;&#x2022; Dashed borders — security group boundaries" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;overflow=hidden;fontSize=9;fontColor=#333333;" vertex="1" parent="1">
