        <!-- ============ SECURITY MECHANISMS LEGEND ============ -->

        <!-- Security Legend Box -->
        <mxCell id="legend" value="Security Isolation Mechanisms" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#B85450;fontSize=11;fontStyle=5;verticalAlign=top;align=center;spacingTop=3;" vertex="1" parent="1">
          <mxGeometry x="1250" y="1100" width="540" height="180" as="geometry" />
        </mxCell>

        <mxCell id="legend-text" value="&#xa;&#x2022; Isolated VPC — no peering, TGW, or VPN&#xa;&#x2022; Private subnet — no public IPs on instances&#xa;&#x2022; Deny-all default SG replaces AWS default&#xa;&#x2022; Route 53 DNS Firewall — allowlist-only DNS&#xa;&#x2022; S3 VPCE-gated bucket policy — no public access&#xa;&#x2022; KMS CMK with auto-rotation for encryption&#xa;&#x2022; IMDSv2 enforced — mitigates SSRF&#xa;&#x2022; Permissions boundary — prevents privilege escalation&#xa;&#x2022; SSM-only access — no SSH/RDP, all sessions logged&#xa;&#x2022; VPC Flow Logs — all traffic captured (90d retention)&#xa;&#x2022; GuardDuty — automated malware &amp; threat detection" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;overflow=hidden;fontSize=9;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="1260" y="1120" width="520" height="150" as="geometry" />
        </mxCell>

