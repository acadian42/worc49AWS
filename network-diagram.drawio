        <mxCell id="default-sg-note" value="Default SG: DENY ALL&#xa;(replaces AWS permissive default)" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#F8CECC;strokeColor=#B85450;fontSize=9;align=left;verticalAlign=top;spacingLeft=5;spacingTop=5;" vertex="1" parent="1">
