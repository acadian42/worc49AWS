        <mxCell id="analyst" value="Security Analyst&#xa;(IAM User)&#xa;Group: malware-lab-dev-analysts&#xa;ABAC SSM Policy" style="outlineConnect=0;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.users;labelBackgroundColor=none;fontSize=10;fontStyle=1;fillColor=#DD344C;strokeColor=#232F3E;" vertex="1" parent="1">
