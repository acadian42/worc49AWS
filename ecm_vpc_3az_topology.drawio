        <!-- ============= Notes ============= -->
        <mxCell id="notes" value="&lt;b&gt;Notes for ECM Review&lt;/b&gt;&#xa;&#xa;• Single subnet per AZ (/26 each) inside a /24 VPC, per ECM ops team IP-conservation guidance.&#xa;• Tier isolation enforced via Security Groups (not subnet boundaries).&#xa;• 3-AZ spread preserved for: ALB fault tolerance, Fargate task distribution, RDS Multi-AZ standby, Aurora reader replication, ElastiCache Multi-AZ replication.&#xa;• RDS Multi-AZ requires standby in a different AZ from primary — satisfied by 1a/1b placement.&#xa;• Aurora &amp; ElastiCache replicas distributed across all 3 AZs for read scaling and failover headroom.&#xa;• All VPC endpoint ENIs deployed in each AZ for HA.&#xa;• Egress routes back through on-prem via Transit Gateway — no public subnet or IGW required." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fffbe6;strokeColor=#d68a1f;strokeWidth=2;verticalAlign=top;align=left;spacingLeft=12;spacingTop=10;fontSize=11;fontColor=#222222;" vertex="1" parent="1">
          <mxGeometry x="40" y="1070" width="980" height="170" as="geometry"/>
        </mxCell>

