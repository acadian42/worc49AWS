<mxfile host="app.diagrams.net" type="device" agent="strategy-diagram-generator"><diagram id="p_overview" name="1 - Inspection Points Overview"><mxGraphModel dx="900" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="780" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="ttl" value="SMD Network Security &amp; Segmentation — Inspection Points" style="text;html=1;whiteSpace=wrap;fillColor=none;strokeColor=none;fontColor=#1A1A1A;fontSize=20;align=center;verticalAlign=middle;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="250" y="18" width="700" height="34" as="geometry"/></mxCell><mxCell id="banner" value="&lt;b&gt;Core principle: inspect once at the optimal point — not everywhere along the path.&lt;/b&gt; No traffic flow is inspected at the same depth in more than one place." style="html=1;whiteSpace=wrap;rounded=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontColor=#1A1A1A;fontSize=11;align=center;verticalAlign=middle;arcSize=8;" vertex="1" parent="1"><mxGeometry x="150" y="60" width="900" height="44" as="geometry"/></mxCell><mxCell id="t1" value="&lt;b&gt;TIER 1 · SITE / OFFICE&lt;/b&gt;&lt;br&gt;Site firewall (SD-WAN / MPLS router)&lt;br&gt;&lt;br&gt;&lt;b&gt;Inspection: Stateful (SPI)&lt;/b&gt;&lt;br&gt;Zone separation (VLANs) · N/S ACL&lt;br&gt;&lt;b&gt;NO DPI · NO IPS&lt;/b&gt; (handled upstream)" style="html=1;whiteSpace=wrap;rounded=1;fillColor=#D5E8D4;strokeColor=#82B366;fontColor=#1A1A1A;fontSize=11;align=center;verticalAlign=middle;arcSize=8;" vertex="1" parent="1"><mxGeometry x="60" y="330" width="250" height="165" as="geometry"/></mxCell><mxCell id="t0" value="&lt;b&gt;TIER 0 · INTERNET EDGE&lt;/b&gt;&lt;br&gt;Cloud Proxy / Security Service Edge (SSE)&lt;br&gt;&lt;br&gt;&lt;b&gt;Inspection: Web / SaaS DPI (cloud-delivered)&lt;/b&gt;&lt;br&gt;SWG · URL filtering · SSL inspection&lt;br&gt;malware scanning · DLP · DNS security" style="html=1;whiteSpace=wrap;rounded=1;fillColor=#E6CCDD;strokeColor=#A64D79;fontColor=#1A1A1A;fontSize=11;align=center;verticalAlign=middle;arcSize=8;" vertex="1" parent="1"><mxGeometry x="470" y="95" width="290" height="150" as="geometry"/></mxCell><mxCell id="t2" value="&lt;b&gt;TIER 2 · HUB (Colocation / DC)&lt;/b&gt;&lt;br&gt;Hub firewall — most capable hardware&lt;br&gt;&lt;br&gt;&lt;b&gt;★ Inspection: DPI + IPS / IDS + Anti-Malware&lt;/b&gt;&lt;br&gt;Single deep-inspection point on the WAN path&lt;br&gt;Threat-intel feeds · service-based rules (transitional)" style="html=1;whiteSpace=wrap;rounded=1;fillColor=#F8CECC;strokeColor=#B85450;fontColor=#1A1A1A;fontSize=11;align=center;verticalAlign=middle;arcSize=8;" vertex="1" parent="1"><mxGeometry x="470" y="330" width="290" height="165" as="geometry"/></mxCell><mxCell id="t3" value="&lt;b&gt;TIER 3 · CLOUD WORKLOAD&lt;/b&gt;&lt;br&gt;Hosted virtualization / native cloud&lt;br&gt;&lt;br&gt;&lt;b&gt;Inspection: Micro-segmentation (L4–L7)&lt;/b&gt;&lt;br&gt;Identity-aware, closest to workload&lt;br&gt;&lt;b&gt;NO DPI re-inspection&lt;/b&gt; (done at hub)" style="html=1;whiteSpace=wrap;rounded=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontColor=#1A1A1A;fontSize=11;align=center;verticalAlign=middle;arcSize=8;" vertex="1" parent="1"><mxGeometry x="900" y="320" width="245" height="130" as="geometry"/></mxCell><mxCell id="dc" value="&lt;b&gt;Legacy Data Center&lt;/b&gt;&lt;br&gt;performs Tier 2 hub role (transitional)" style="html=1;whiteSpace=wrap;rounded=1;fillColor=#F5F5F5;strokeColor=#808080;fontColor=#1A1A1A;fontSize=10;align=center;verticalAlign=middle;arcSize=8;" vertex="1" parent="1"><mxGeometry x="900" y="470" width="245" height="60" as="geometry"/></mxCell><mxCell id="net" value="&lt;b&gt;Internet / SaaS&lt;/b&gt;&lt;br&gt;(M365, Salesforce, web)" style="shape=cloud;html=1;whiteSpace=wrap;fillColor=#F0F0F0;strokeColor=#999999;fontColor=#1A1A1A;fontSize=11;align=center;verticalAlign=middle;arcSize=8;" vertex="1" parent="1"><mxGeometry x="880" y="110" width="200" height="120" as="geometry"/></mxCell><mxCell id="e_t1_t0" value="Internet / SaaS&lt;br&gt;(direct to SSE)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;startArrow=none;strokeColor=#A64D79;strokeWidth=2;fontColor=#333333;fontSize=10;labelBackgroundColor=#FFFFFF;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="t1" target="t0"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e_t0_net" value="inspected egress" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;startArrow=none;strokeColor=#A64D79;strokeWidth=2;fontColor=#333333;fontSize=10;labelBackgroundColor=#FFFFFF;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="t0" target="net"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e_t1_t2" value="WAN: DC / cloud traffic" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;startArrow=none;strokeColor=#B85450;strokeWidth=2;fontColor=#333333;fontSize=10;labelBackgroundColor=#FFFFFF;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="t1" target="t2"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e_t2_t3" value="to cloud workloads" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;startArrow=none;strokeColor=#9673A6;strokeWidth=2;fontColor=#333333;fontSize=10;labelBackgroundColor=#FFFFFF;exitX=1;exitY=0.35;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="t2" target="t3"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e_t2_dc" value="DC-hosted (transitional)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;startArrow=none;strokeColor=#808080;strokeWidth=2;fontColor=#333333;fontSize=10;labelBackgroundColor=#FFFFFF;dashed=1;exitX=1;exitY=0.75;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="t2" target="dc"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="legend" value="&lt;b&gt;Inspection-depth key&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;Stateful (SPI)&lt;/b&gt; — access control / zone enforcement; no payload inspection&lt;br&gt;&lt;br&gt;&lt;b&gt;Deep (DPI + IPS + Anti-Malware)&lt;/b&gt; — full threat inspection of WAN payloads&lt;br&gt;&lt;br&gt;&lt;b&gt;Web / SaaS DPI&lt;/b&gt; — cloud-delivered SWG inspection of user internet / SaaS traffic&lt;br&gt;&lt;br&gt;&lt;b&gt;Micro-segmentation&lt;/b&gt; — identity-aware L4–L7 allow rules at the workload" style="html=1;whiteSpace=wrap;rounded=1;fillColor=#FFFFFF;strokeColor=#999999;fontColor=#1A1A1A;fontSize=10;align=left;verticalAlign=top;arcSize=8;" vertex="1" parent="1"><mxGeometry x="60" y="545" width="540" height="200" as="geometry"/></mxCell><mxCell id="biz" value="&lt;b&gt;What this means for the business&lt;/b&gt;&lt;br&gt;&lt;br&gt;• Lower latency for warehouse &amp; SaaS apps — deep-inspected once, not repeatedly.&lt;br&gt;• Internet / SaaS tunnels straight to the SSE cloud — no backhaul through the hub.&lt;br&gt;• Clear ownership — one team owns deep inspection (hub), simplifying troubleshooting.&lt;br&gt;• Posture preserved as workloads move to cloud — the enforcement mechanism changes, the policy does not." style="html=1;whiteSpace=wrap;rounded=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontColor=#1A1A1A;fontSize=10;align=left;verticalAlign=top;arcSize=8;" vertex="1" parent="1"><mxGeometry x="620" y="545" width="525" height="200" as="geometry"/></mxCell></root></mxGraphModel></diagram><diagram id="p_flow1" name="2 - Flow: User to Cloud App"><mxGraphModel dx="900" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="560" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="ttl" value="Traffic Flow 1 — Warehouse User → Application in the Cloud" style="text;html=1;whiteSpace=wrap;fillColor=none;strokeColor=none;fontColor=#1A1A1A;fontSize=19;align=left;verticalAlign=middle;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="60" y="22" width="1080" height="30" as="geometry"/></mxCell><mxCell id="sub" value="Internal application access (e.g., WMS). Inspect once at the optimal point." style="text;html=1;whiteSpace=wrap;fillColor=none;strokeColor=none;fontColor=#555555;fontSize=12;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="60" y="56" width="1080" height="24" as="geometry"/></mxCell><mxCell id="u" value="&lt;b&gt;Warehouse User&lt;/b&gt;&lt;br&gt;(Operations VLAN)" style="html=1;whiteSpace=wrap;rounded=1;fillColor=#FFE6CC;strokeColor=#D79B00;fontColor=#1A1A1A;fontSize=11;align=center;verticalAlign=middle;arcSize=8;" vertex="1" parent="1"><mxGeometry x="60.0" y="150" width="215" height="150" as="geometry"/></mxCell><mxCell id="s1" value="&lt;b&gt;TIER 1 · Site Firewall&lt;/b&gt;&lt;br&gt;&lt;i&gt;Stateful (SPI)&lt;/i&gt;&lt;br&gt;&lt;br&gt;ACL permits DC / cloud ranges&lt;br&gt;No DPI / IPS" style="html=1;whiteSpace=wrap;rounded=1;fillColor=#D5E8D4;strokeColor=#82B366;fontColor=#1A1A1A;fontSize=11;align=center;verticalAlign=middle;arcSize=8;" vertex="1" parent="1"><mxGeometry x="348.3333333333333" y="150" width="215" height="150" as="geometry"/></mxCell><mxCell id="s2" value="&lt;b&gt;TIER 2 · Hub Firewall&lt;/b&gt;&lt;br&gt;&lt;i&gt;Deep: DPI + IPS + Anti-Malware&lt;/i&gt;&lt;br&gt;&lt;br&gt;Single deep-inspection point&lt;br&gt;Threat-intel applied" style="html=1;whiteSpace=wrap;rounded=1;fillColor=#F8CECC;strokeColor=#B85450;fontColor=#1A1A1A;fontSize=11;align=center;verticalAlign=middle;arcSize=8;" vertex="1" parent="1"><mxGeometry x="636.6666666666666" y="150" width="215" height="150" as="geometry"/></mxCell><mxCell id="s3" value="&lt;b&gt;TIER 3 · Cloud Workload (WMS)&lt;/b&gt;&lt;br&gt;&lt;i&gt;Micro-segmentation&lt;/i&gt;&lt;br&gt;&lt;br&gt;Permits this user → WMS on required ports&lt;br&gt;No DPI re-inspection" style="html=1;whiteSpace=wrap;rounded=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontColor=#1A1A1A;fontSize=11;align=center;verticalAlign=middle;arcSize=8;" vertex="1" parent="1"><mxGeometry x="925.0" y="150" width="215" height="150" as="geometry"/></mxCell><mxCell id="e0" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;startArrow=none;strokeColor=#555555;strokeWidth=2;fontColor=#333333;fontSize=10;labelBackgroundColor=#FFFFFF;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="u" target="s1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e1" value="WAN path" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;startArrow=none;strokeColor=#555555;strokeWidth=2;fontColor=#333333;fontSize=10;labelBackgroundColor=#FFFFFF;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="s1" target="s2"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e2" value="to workload" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;startArrow=none;strokeColor=#555555;strokeWidth=2;fontColor=#333333;fontSize=10;labelBackgroundColor=#FFFFFF;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="s2" target="s3"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="note" value="&lt;b&gt;Inspection points: 3&lt;/b&gt; — Stateful → Deep → Micro-segmentation. &lt;b&gt;Deep packet inspection performed once&lt;/b&gt; (at the hub) — no duplication.&lt;br&gt;Approx. added latency: Site negligible (≤1 ms) · Hub 5–15 ms · Cloud negligible." style="html=1;whiteSpace=wrap;rounded=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontColor=#1A1A1A;fontSize=11;align=left;verticalAlign=middle;arcSize=8;" vertex="1" parent="1"><mxGeometry x="60" y="430" width="1080" height="95" as="geometry"/></mxCell></root></mxGraphModel></diagram><diagram id="p_flow2" name="3 - Flow: User to Internet/SaaS"><mxGraphModel dx="900" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="560" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="ttl" value="Traffic Flow 2 — Warehouse User → Internet / SaaS" style="text;html=1;whiteSpace=wrap;fillColor=none;strokeColor=none;fontColor=#1A1A1A;fontSize=19;align=left;verticalAlign=middle;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="60" y="22" width="1080" height="30" as="geometry"/></mxCell><mxCell id="sub" value="Internet &amp; SaaS traffic tunnels directly to the SSE cloud — the hub is not involved." style="text;html=1;whiteSpace=wrap;fillColor=none;strokeColor=none;fontColor=#555555;fontSize=12;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="60" y="56" width="1080" height="24" as="geometry"/></mxCell><mxCell id="u" value="&lt;b&gt;Warehouse User&lt;/b&gt;&lt;br&gt;(Operations VLAN)" style="html=1;whiteSpace=wrap;rounded=1;fillColor=#FFE6CC;strokeColor=#D79B00;fontColor=#1A1A1A;fontSize=11;align=center;verticalAlign=middle;arcSize=8;" vertex="1" parent="1"><mxGeometry x="60.0" y="150" width="215" height="150" as="geometry"/></mxCell><mxCell id="s1" value="&lt;b&gt;TIER 1 · Site Firewall&lt;/b&gt;&lt;br&gt;&lt;i&gt;Stateful (SPI)&lt;/i&gt;&lt;br&gt;&lt;br&gt;Permits internet via cloud proxy&lt;br&gt;Tunnels direct to SSE" style="html=1;whiteSpace=wrap;rounded=1;fillColor=#D5E8D4;strokeColor=#82B366;fontColor=#1A1A1A;fontSize=11;align=center;verticalAlign=middle;arcSize=8;" vertex="1" parent="1"><mxGeometry x="348.3333333333333" y="150" width="215" height="150" as="geometry"/></mxCell><mxCell id="s2" value="&lt;b&gt;TIER 0 · Cloud Proxy / SSE&lt;/b&gt;&lt;br&gt;&lt;i&gt;Web / SaaS DPI (cloud-delivered)&lt;/i&gt;&lt;br&gt;&lt;br&gt;URL filtering · SSL inspection&lt;br&gt;malware scanning · DLP" style="html=1;whiteSpace=wrap;rounded=1;fillColor=#E6CCDD;strokeColor=#A64D79;fontColor=#1A1A1A;fontSize=11;align=center;verticalAlign=middle;arcSize=8;" vertex="1" parent="1"><mxGeometry x="636.6666666666666" y="150" width="215" height="150" as="geometry"/></mxCell><mxCell id="s3" value="&lt;b&gt;Internet / SaaS&lt;/b&gt;&lt;br&gt;(M365, Salesforce, web)" style="html=1;whiteSpace=wrap;rounded=1;fillColor=#F0F0F0;strokeColor=#999999;fontColor=#1A1A1A;fontSize=11;align=center;verticalAlign=middle;arcSize=8;" vertex="1" parent="1"><mxGeometry x="925.0" y="150" width="215" height="150" as="geometry"/></mxCell><mxCell id="e0" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;startArrow=none;strokeColor=#555555;strokeWidth=2;fontColor=#333333;fontSize=10;labelBackgroundColor=#FFFFFF;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="u" target="s1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e1" value="GRE / IPsec" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;startArrow=none;strokeColor=#555555;strokeWidth=2;fontColor=#333333;fontSize=10;labelBackgroundColor=#FFFFFF;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="s1" target="s2"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e2" value="inspected egress" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;startArrow=none;strokeColor=#555555;strokeWidth=2;fontColor=#333333;fontSize=10;labelBackgroundColor=#FFFFFF;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="s2" target="s3"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="byp" value="&lt;b&gt;TIER 2 · Hub&lt;/b&gt; — bypassed for internet / SaaS&lt;br&gt;(no hub backhaul)" style="html=1;whiteSpace=wrap;rounded=1;fillColor=#F2F2F2;strokeColor=#B0B0B0;fontColor=#777777;fontSize=10;align=center;verticalAlign=middle;arcSize=8;dashed=1;" vertex="1" parent="1"><mxGeometry x="350" y="350" width="360" height="70" as="geometry"/></mxCell><mxCell id="bypx" value="✕ not in path" style="text;html=1;whiteSpace=wrap;fillColor=none;strokeColor=none;fontColor=#CC0000;fontSize=12;align=left;verticalAlign=middle;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="715" y="350" width="120" height="70" as="geometry"/></mxCell><mxCell id="note" value="&lt;b&gt;Inspection points: 2&lt;/b&gt; — Stateful → Cloud Proxy (SSE). &lt;b&gt;The hub is NOT involved&lt;/b&gt; — no DPI duplication, no backhaul latency.&lt;br&gt;Foundation for future SASE: hub controls progressively shift to the SSE cloud." style="html=1;whiteSpace=wrap;rounded=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontColor=#1A1A1A;fontSize=11;align=left;verticalAlign=middle;arcSize=8;" vertex="1" parent="1"><mxGeometry x="60" y="430" width="1080" height="95" as="geometry"/></mxCell></root></mxGraphModel></diagram><diagram id="p_flow3" name="4 - Flow: Site-to-Site (Exception)"><mxGraphModel dx="900" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="560" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="ttl" value="Traffic Flow 3 — Site-to-Site (Exception-Based)" style="text;html=1;whiteSpace=wrap;fillColor=none;strokeColor=none;fontColor=#1A1A1A;fontSize=19;align=left;verticalAlign=middle;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="60" y="22" width="1080" height="30" as="geometry"/></mxCell><mxCell id="sub" value="Denied by default; granted exceptions are inspected at the hub, not at both ends." style="text;html=1;whiteSpace=wrap;fillColor=none;strokeColor=none;fontColor=#555555;fontSize=12;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="60" y="56" width="1080" height="24" as="geometry"/></mxCell><mxCell id="s1" value="&lt;b&gt;Source Site · Tier 1&lt;/b&gt;&lt;br&gt;&lt;i&gt;Stateful (SPI)&lt;/i&gt;&lt;br&gt;&lt;br&gt;Exception ACL permits →&lt;br&gt;destination service" style="html=1;whiteSpace=wrap;rounded=1;fillColor=#D5E8D4;strokeColor=#82B366;fontColor=#1A1A1A;fontSize=11;align=center;verticalAlign=middle;arcSize=8;" vertex="1" parent="1"><mxGeometry x="60.0" y="150" width="215" height="150" as="geometry"/></mxCell><mxCell id="s2" value="&lt;b&gt;TIER 2 · Hub Firewall&lt;/b&gt;&lt;br&gt;&lt;i&gt;Deep: DPI + IPS&lt;/i&gt;&lt;br&gt;&lt;br&gt;Inspects cross-site traffic" style="html=1;whiteSpace=wrap;rounded=1;fillColor=#F8CECC;strokeColor=#B85450;fontColor=#1A1A1A;fontSize=11;align=center;verticalAlign=middle;arcSize=8;" vertex="1" parent="1"><mxGeometry x="492.5" y="150" width="215" height="150" as="geometry"/></mxCell><mxCell id="s3" value="&lt;b&gt;Destination Site · Tier 1&lt;/b&gt;&lt;br&gt;&lt;i&gt;Stateful (SPI)&lt;/i&gt;&lt;br&gt;&lt;br&gt;Permits inbound from approved source&lt;br&gt;(IPS on inbound exception traffic)" style="html=1;whiteSpace=wrap;rounded=1;fillColor=#D5E8D4;strokeColor=#82B366;fontColor=#1A1A1A;fontSize=11;align=center;verticalAlign=middle;arcSize=8;" vertex="1" parent="1"><mxGeometry x="925.0" y="150" width="215" height="150" as="geometry"/></mxCell><mxCell id="e0" value="exception traffic" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;startArrow=none;strokeColor=#555555;strokeWidth=2;fontColor=#333333;fontSize=10;labelBackgroundColor=#FFFFFF;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="s1" target="s2"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e1" value="inspected" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;startArrow=none;strokeColor=#555555;strokeWidth=2;fontColor=#333333;fontSize=10;labelBackgroundColor=#FFFFFF;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="s2" target="s3"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="note" value="&lt;b&gt;Default: site-to-site is denied (RFC 1918 deny).&lt;/b&gt; Exceptions are audited and time-bound.&lt;br&gt;&lt;b&gt;Inspection points: 3&lt;/b&gt; — Stateful → Deep → Stateful. Target state: reach the application via the cloud instead — removing east-west spread risk." style="html=1;whiteSpace=wrap;rounded=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontColor=#1A1A1A;fontSize=11;align=left;verticalAlign=middle;arcSize=8;" vertex="1" parent="1"><mxGeometry x="60" y="430" width="1080" height="95" as="geometry"/></mxCell></root></mxGraphModel></diagram><diagram id="p_matrix" name="5 - Enforcement Point Matrix"><mxGraphModel dx="900" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="760" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="ttl" value="Enforcement Point Matrix — Where Each Inspection Happens" style="text;html=1;whiteSpace=wrap;fillColor=none;strokeColor=none;fontColor=#1A1A1A;fontSize=19;align=left;verticalAlign=middle;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="60" y="22" width="1080" height="30" as="geometry"/></mxCell><mxCell id="sub" value="Authoritative reference — no control is enforced at the same depth in two places. Primary = point of record." style="text;html=1;whiteSpace=wrap;fillColor=none;strokeColor=none;fontColor=#555555;fontSize=12;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="60" y="56" width="1080" height="22" as="geometry"/></mxCell><mxCell id="h_lbl" value="&lt;b&gt;Inspection control&lt;/b&gt;" style="html=1;whiteSpace=wrap;rounded=1;fillColor=#D9D9D9;strokeColor=#999999;fontColor=#1A1A1A;fontSize=11;align=center;verticalAlign=middle;arcSize=8;" vertex="1" parent="1"><mxGeometry x="60" y="110" width="250" height="50" as="geometry"/></mxCell><mxCell id="h0" value="&lt;b&gt;Site FW&lt;br&gt;(Tier 1)&lt;/b&gt;" style="html=1;whiteSpace=wrap;rounded=1;fillColor=#D5E8D4;strokeColor=#82B366;fontColor=#1A1A1A;fontSize=10;align=center;verticalAlign=middle;arcSize=8;" vertex="1" parent="1"><mxGeometry x="310" y="110" width="175" height="50" as="geometry"/></mxCell><mxCell id="h1" value="&lt;b&gt;Hub FW&lt;br&gt;(Tier 2)&lt;/b&gt;" style="html=1;whiteSpace=wrap;rounded=1;fillColor=#F8CECC;strokeColor=#B85450;fontColor=#1A1A1A;fontSize=10;align=center;verticalAlign=middle;arcSize=8;" vertex="1" parent="1"><mxGeometry x="485" y="110" width="175" height="50" as="geometry"/></mxCell><mxCell id="h2" value="&lt;b&gt;Cloud µ-seg&lt;br&gt;(Tier 3)&lt;/b&gt;" style="html=1;whiteSpace=wrap;rounded=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontColor=#1A1A1A;fontSize=10;align=center;verticalAlign=middle;arcSize=8;" vertex="1" parent="1"><mxGeometry x="660" y="110" width="175" height="50" as="geometry"/></mxCell><mxCell id="h3" value="&lt;b&gt;Cloud Proxy /&lt;br&gt;SSE (Tier 0)&lt;/b&gt;" style="html=1;whiteSpace=wrap;rounded=1;fillColor=#E6CCDD;strokeColor=#A64D79;fontColor=#1A1A1A;fontSize=10;align=center;verticalAlign=middle;arcSize=8;" vertex="1" parent="1"><mxGeometry x="835" y="110" width="175" height="50" as="geometry"/></mxCell><mxCell id="h4" value="&lt;b&gt;SMD DC&lt;br&gt;(transitional)&lt;/b&gt;" style="html=1;whiteSpace=wrap;rounded=1;fillColor=#F5F5F5;strokeColor=#808080;fontColor=#1A1A1A;fontSize=10;align=center;verticalAlign=middle;arcSize=8;" vertex="1" parent="1"><mxGeometry x="1010" y="110" width="175" height="50" as="geometry"/></mxCell><mxCell id="r0" value="&lt;b&gt;Stateful Packet Inspection&lt;/b&gt;" style="html=1;whiteSpace=wrap;rounded=1;fillColor=#F4F4F4;strokeColor=#CCCCCC;fontColor=#1A1A1A;fontSize=10;align=left;verticalAlign=middle;arcSize=8;" vertex="1" parent="1"><mxGeometry x="60" y="160" width="250" height="56" as="geometry"/></mxCell><mxCell id="c0_0" value="Primary" style="html=1;whiteSpace=wrap;rounded=1;fillColor=#B6D7A8;strokeColor=#6AA84F;fontColor=#1A1A1A;fontSize=10;align=center;verticalAlign=middle;arcSize=8;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="310" y="160" width="175" height="56" as="geometry"/></mxCell><mxCell id="c0_1" value="Yes" style="html=1;whiteSpace=wrap;rounded=1;fillColor=#D9EAD3;strokeColor=#93C47D;fontColor=#1A1A1A;fontSize=10;align=center;verticalAlign=middle;arcSize=8;" vertex="1" parent="1"><mxGeometry x="485" y="160" width="175" height="56" as="geometry"/></mxCell><mxCell id="c0_2" value="N/A" style="html=1;whiteSpace=wrap;rounded=1;fillColor=#FAFAFA;strokeColor=#E0E0E0;fontColor=#9E9E9E;fontSize=10;align=center;verticalAlign=middle;arcSize=8;" vertex="1" parent="1"><mxGeometry x="660" y="160" width="175" height="56" as="geometry"/></mxCell><mxCell id="c0_3" value="N/A" style="html=1;whiteSpace=wrap;rounded=1;fillColor=#FAFAFA;strokeColor=#E0E0E0;fontColor=#9E9E9E;fontSize=10;align=center;verticalAlign=middle;arcSize=8;" vertex="1" parent="1"><mxGeometry x="835" y="160" width="175" height="56" as="geometry"/></mxCell><mxCell id="c0_4" value="Yes" style="html=1;whiteSpace=wrap;rounded=1;fillColor=#D9EAD3;strokeColor=#93C47D;fontColor=#1A1A1A;fontSize=10;align=center;verticalAlign=middle;arcSize=8;" vertex="1" parent="1"><mxGeometry x="1010" y="160" width="175" height="56" as="geometry"/></mxCell><mxCell id="r1" value="&lt;b&gt;Deep Packet Inspection&lt;/b&gt;" style="html=1;whiteSpace=wrap;rounded=1;fillColor=#F4F4F4;strokeColor=#CCCCCC;fontColor=#1A1A1A;fontSize=10;align=left;verticalAlign=middle;arcSize=8;" vertex="1" parent="1"><mxGeometry x="60" y="216" width="250" height="56" as="geometry"/></mxCell><mxCell id="c1_0" value="Optional (S2S)" style="html=1;whiteSpace=wrap;rounded=1;fillColor=#FFE599;strokeColor=#D6B656;fontColor=#1A1A1A;fontSize=10;align=center;verticalAlign=middle;arcSize=8;" vertex="1" parent="1"><mxGeometry x="310" y="216" width="175" height="56" as="geometry"/></mxCell><mxCell id="c1_1" value="Primary" style="html=1;whiteSpace=wrap;rounded=1;fillColor=#B6D7A8;strokeColor=#6AA84F;fontColor=#1A1A1A;fontSize=10;align=center;vertical