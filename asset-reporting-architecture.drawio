          <mxGeometry x="40" y="960" width="1480" height="160" as="geometry" />
        </mxCell>
        <mxCell id="scale-title" value="Scale-out considerations" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=14;fontStyle=1;fontColor=#7a5c00" vertex="1" parent="1">
          <mxGeometry x="60" y="970" width="400" height="25" as="geometry" />
        </mxCell>
        <mxCell id="scale-1" value="• &lt;b&gt;New sources:&lt;/b&gt; drop in a new Cloud Run puller + Pub/Sub topic. Zero changes downstream — Dataflow picks it up from a new subscription." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="60" y="1000" width="720" height="25" as="geometry" />
        </mxCell>
        <mxCell id="scale-2" value="• &lt;b&gt;Volume:&lt;/b&gt; Pub/Sub + Dataflow auto-scale. BigQuery slot-based pricing scales with query load. Cloud Run scales 0 &#8594; N per puller independently." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="60" y="1025" width="720" height="25" as="geometry" />
        </mxCell>
        <mxCell id="scale-3" value="• &lt;b&gt;Retention:&lt;/b&gt; BigQuery partitioning (date) + clustering (serial, tool). Cold data tiered to GCS Nearline/Coldline via lifecycle policy." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="60" y="1050" width="720" height="25" as="geometry" />
        </mxCell>
        <mxCell id="scale-4" value="• &lt;b&gt;HA / geography:&lt;/b&gt; Cloud Spanner multi-region config for matched asset table. BigQuery multi-region dataset. Pub/Sub is regional or global." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="60" y="1075" width="720" height="25" as="geometry" />
        </mxCell>
        <mxCell id="scale-5" value="• &lt;b&gt;Matching cost:&lt;/b&gt; serial-key indexed in Spanner for O(1) lookup. Heavy joins pushed down to BQ." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="790" y="1000" width="720" height="25" as="geometry" />
        </mxCell>
        <mxCell id="scale-6" value="• &lt;b&gt;AI load:&lt;/b&gt; Vertex AI Agent Builder horizontally scales. Rate-limit per user at Query API layer. Cache common NL&#8594;SQL translations." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="790" y="1025" width="720" height="25" as="geometry" />
        </mxCell>
        <mxCell id="scale-7" value="• &lt;b&gt;Governance:&lt;/b&gt; Dataplex / Data Catalog tracks schema across sources — essential as tool count grows." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="790" y="1050" width="720" height="25" as="geometry" />
        </mxCell>
        <mxCell id="scale-8" value="• &lt;b&gt;Alt path (from chat):&lt;/b&gt; if Eric already has a data taxonomy / unified dataset, attach the AI agent directly to his data to shortcut ingestion." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=12;fontStyle=2" vertex="1" parent="1">
          <mxGeometry x="790" y="1075" width="720" height="25" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
