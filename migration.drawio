          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="arrow2_label" value="&lt;b&gt;Step 2: Pull &amp; Transform&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#666666&quot;&gt;S3 GET → EC2&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#009900&quot;&gt;&lt;b&gt;Same-region = $0 transfer&lt;/b&gt;&lt;/font&gt;" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;" vertex="1" connectable="0" parent="arrow2">
          <mxGeometry x="-0.1" y="-1" relative="1" as="geometry">
