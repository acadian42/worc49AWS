          </mxGeometry>
        </mxCell>

        <!-- EC2 Transform -->
        <mxCell id="ec2_container" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="760" y="130" width="280" height="180" as="geometry"/>
        </mxCell>
        <mxCell id="ec2_label" value="&lt;b&gt;EC2 Worker Instance(s)&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#666666&quot;&gt;AWS Commercial (us-west-1)&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="795" y="140" width="220" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="ec2_icon" value="" style="outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#ED7100;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;pointerEvents=1;shape=mxgraph.aws4.instance2;" vertex="1" parent="1">
          <mxGeometry x="870" y="180" width="48" height="48" as="geometry"/>
        </mxCell>
        <mxCell id="ec2_process" value="&lt;b&gt;Stream Transform:&lt;/b&gt;&lt;br&gt;zstd -d --stdout file.zst&lt;br&gt;| gzip&lt;br&gt;| POST → CrowdStrike ingest&lt;br&gt;&lt;font color=&quot;#888888&quot;&gt;Recommended: c6i.2xlarge&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="790" y="245" width="195" height="70" as="geometry"/>
        </mxCell>

        <!-- Arrow 3: EC2 to CrowdStrike -->
        <mxCell id="arrow3" value="" style="endArrow=block;endFill=1;html=1;strokeWidth=3;strokeColor=#b85450;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="ec2_container" target="cs_container">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="arrow3_label" value="&lt;b&gt;Step 3: Ingest&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#666666&quot;&gt;HTTPS POST (gzip)&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#cc0000&quot;&gt;&lt;b&gt;Internet egress = $$$ &lt;/b&gt;&lt;/font&gt;" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;" vertex="1" connectable="0" parent="arrow3">
          <mxGeometry x="-0.1" y="-1" relative="1" as="geometry">
            <mxPoint y="-35" as="offset"/>
          </mxGeometry>
        </mxCell>

        <!-- CrowdStrike GovCloud -->
        <mxCell id="cs_container" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="1170" y="130" width="260" height="180" as="geometry"/>
        </mxCell>
        <mxCell id="cs_label" value="&lt;b&gt;CrowdStrike Falcon LogScale&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#666666&quot;&gt;AWS GovCloud (us-gov-west-1)&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1180" y="140" width="240" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="cs_icon" value="🛡️" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=36;" vertex="1" parent="1">
          <mxGeometry x="1275" y="185" width="55" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="cs_details" value="&lt;b&gt;Ingest Endpoint (confirmed reachable)&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#888888&quot;&gt;HTTP Endpoint or API Endpoint&lt;br&gt;(TBD — confirm with CrowdStrike)&lt;br&gt;Accepts: gzip compressed logs&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1185" y="250" width="230" height="60" as="geometry"/>
        </mxCell>

        <!-- ============================================ -->
        <!-- PARTITION WALL CALLOUT -->
        <!-- ============================================ -->
        <mxCell id="partition_wall" value="" style="shape=mxgraph.basic.patternFillRect;fillStyle=diagGrid;step=4;fillStrokeWidth=0.2;fillStrokeColor=#cc0000;strokeColor=#cc0000;strokeWidth=2;dashed=1;dashPattern=8 4;opacity=30;" vertex="1" parent="1">
          <mxGeometry x="1150" y="120" width="10" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="partition_label" value="&lt;font color=&quot;#cc0000&quot;&gt;&lt;b&gt;AWS PARTITION&lt;br&gt;BOUNDARY&lt;/b&gt;&lt;br&gt;Commercial ↔ GovCloud&lt;br&gt;IAM cannot cross&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="1095" y="325" width="120" height="60" as="geometry"/>
        </mxCell>

        <!-- ============================================ -->
        <!-- SECTION 2: OPTION COMPARISON -->
        <!-- ============================================ -->
        <mxCell id="section2_label" value="&lt;b&gt;ARCHITECTURE OPTIONS COMPARISON&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=14;fontColor=#1a1a2e;" vertex="1" parent="1">
          <mxGeometry x="40" y="420" width="320" height="30" as="geometry"/>
        </mxCell>

        <!-- Option A: EC2 Streaming (Recommended) -->
        <mxCell id="optA_container" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;arcSize=6;strokeWidth=3;" vertex="1" parent="1">
          <mxGeometry x="40" y="460" width="440" height="320" as="geometry"/>
        </mxCell>
        <mxCell id="optA_badge" value="&lt;b&gt;✅ RECOMMENDED&lt;/b&gt;" style="label;whiteSpace=wrap;html=1;fillColor=#82b366;strokeColor=none;fontColor=#ffffff;fontSize=11;rounded=1;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="315" y="470" width="150" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="optA_title" value="&lt;b&gt;Option A: EC2 Stream-Through to HTTP Ingest&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=13;fontColor=#2d6a2e;" vertex="1" parent="1">
          <mxGeometry x="55" y="468" width="365" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="optA_flow" value="&lt;div style=&quot;text-align:left;&quot;&gt;&lt;b&gt;Flow:&lt;/b&gt; AW S3 → Your S3 → EC2 → CrowdStrike Ingest URL&lt;br&gt;&lt;br&gt;&lt;b&gt;How it works:&lt;/b&gt;&lt;br&gt;• aws s3 sync from Arctic Wolf bucket to yours&lt;br&gt;• EC2 streams: zstd decompress → gzip recompress → HTTP POST&lt;br&gt;• No intermediate uncompressed data lands on disk&lt;br&gt;• Parallelizable across multiple instances or GNU parallel&lt;br&gt;&lt;br&gt;&lt;b&gt;Pros:&lt;/b&gt;&lt;br&gt;• Works TODAY — no dependency on CrowdStrike fixing IAM role&lt;br&gt;• Minimal AWS resources (1-3 EC2 instances)&lt;br&gt;• Simple to build, monitor, and debug&lt;br&gt;• Stream-through avoids needing 160TB disk&lt;br&gt;&lt;br&gt;&lt;b&gt;Cons:&lt;/b&gt;&lt;br&gt;• Must handle batching (5K events / 5MB per API request)&lt;br&gt;• Need retry logic for HTTP failures&lt;br&gt;• Full internet egress cost on gzip output&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=10;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="495" width="420" height="270" as="geometry"/>
        </mxCell>

        <!-- Option B: S3/SQS Ingest Feed (Blocked) -->
        <mxCell id="optB_container" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;arcSize=6;strokeWidth=2;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="520" y="460" width="440" height="320" as="geometry"/>
        </mxCell>
        <mxCell id="optB_badge" value="&lt;b&gt;🚫 BLOCKED&lt;/b&gt;" style="label;whiteSpace=wrap;html=1;fillColor=#d6b656;strokeColor=none;fontColor=#ffffff;fontSize=11;rounded=1;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="800" y="470" width="145" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="optB_title" value="&lt;b&gt;Option B: S3 Landing Zone + SQS Ingest Feed&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=13;fontColor=#8c7a1e;" vertex="1" parent="1">
          <mxGeometry x="535" y="468" width="365" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="optB_flow" value="&lt;div style=&quot;text-align:left;&quot;&gt;&lt;b&gt;Flow:&lt;/b&gt; AW S3 → Your S3 → EC2 (transform) → S3 (.gz) → SQS → CS&lt;br&gt;&lt;br&gt;&lt;b&gt;How it works:&lt;/b&gt;&lt;br&gt;• Copy ZST to your bucket, EC2 transforms to gzip, writes back to S3&lt;br&gt;• CrowdStrike LogScale S3 ingest feed reads .gz from S3 via SQS&lt;br&gt;• CrowdStrike manages pull &amp; ingest automatically&lt;br&gt;&lt;br&gt;&lt;b&gt;Pros:&lt;/b&gt;&lt;br&gt;• CrowdStrike-recommended architecture&lt;br&gt;• No HTTP batching or retry logic needed&lt;br&gt;• Scales automatically on CrowdStrike side&lt;br&gt;&lt;br&gt;&lt;b&gt;Cons:&lt;/b&gt;&lt;br&gt;• ⚠️ BLOCKED: S3 connector requires CrossAccountAccessRole&lt;br&gt;• GovCloud IAM role (arn:aws-us-gov:iam::358431324613:role/&lt;br&gt;  crowdstrike-3pi-laggar-connectors) does not appear to exist&lt;br&gt;• CrowdStrike must confirm/provision the role first&lt;br&gt;• Requires additional S3 storage for .gz intermediary files&lt;br&gt;• Still has egress cost if S3 is in commercial partition&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=10;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="530" y="495" width="420" height="280" as="geometry"/>
        </mxCell>

        <!-- Option C: AWS Batch -->
        <mxCell id="optC_container" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;arcSize=6;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="1000" y="460" width="440" height="320" as="geometry"/>
        </mxCell>
        <mxCell id="optC_badge" value="&lt;b&gt;ALTERNATIVE&lt;/b&gt;" style="label;whiteSpace=wrap;html=1;fillColor=#9673a6;strokeColor=none;fontColor=#ffffff;fontSize=11;rounded=1;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="1280" y="470" width="145" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="optC_title" value="&lt;b&gt;Option C: AWS Batch Managed Compute&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=13;fontColor=#6a4c8a;" vertex="1" parent="1">
          <mxGeometry x="1015" y="468" width="310" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="optC_flow" value="&lt;div style=&quot;text-align:left;&quot;&gt;&lt;b&gt;Flow:&lt;/b&gt; AW S3 → Your S3 → AWS Batch jobs → CrowdStrike Ingest&lt;br&gt;&lt;br&gt;&lt;b&gt;How it works:&lt;/b&gt;&lt;br&gt;• Same transform as Option A but managed by AWS Batch&lt;br&gt;• Batch handles job scheduling, parallelism, retries&lt;br&gt;• Containerized workers (Docker) with same zstd→gzip pipeline&lt;br&gt;&lt;br&gt;&lt;b&gt;Pros:&lt;/b&gt;&lt;br&gt;• Built-in retry, parallel job management, monitoring&lt;br&gt;• Auto-scales workers based on queue depth&lt;br&gt;• Better for very large jobs with many files&lt;br&gt;&lt;br&gt;&lt;b&gt;Cons:&lt;/b&gt;&lt;br&gt;• More setup overhead (job defs, compute envs, containers)&lt;br&gt;• Overkill for a one-time migration&lt;br&gt;• Same egress costs as Option A&lt;br&gt;• Additional complexity for marginal benefit&lt;br&gt;• You still need to build the transform logic anyway&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=10;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1010" y="495" width="420" height="270" as="geometry"/>
        </mxCell>

        <!-- ============================================ -->
        <!-- SECTION 3: COST BREAKDOWN TABLE -->
        <!-- ============================================ -->
        <mxCell id="section3_label" value="&lt;b&gt;COST ESTIMATES (ALL OPTIONS)&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=14;fontColor=#1a1a2e;" vertex="1" parent="1">
          <mxGeometry x="40" y="810" width="280" height="30" as="geometry"/>
        </mxCell>

        <!-- Cost Table Header -->
        <mxCell id="cost_header" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1a1a2e;strokeColor=#1a1a2e;" vertex="1" parent="1">
          <mxGeometry x="40" y="850" width="1400" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="cost_h1" value="&lt;b&gt;&lt;font color=&quot;#ffffff&quot;&gt;Cost Item&lt;/font&gt;&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="852" width="280" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="cost_h2" value="&lt;b&gt;&lt;font color=&quot;#ffffff&quot;&gt;Calculation&lt;/font&gt;&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="320" y="852" width="340" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="cost_h3" value="&lt;b&gt;&lt;font color=&quot;#ffffff&quot;&gt;Option A (EC2 Direct)&lt;/font&gt;&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="660" y="852" width="200" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="cost_h4" value="&lt;b&gt;&lt;font color=&quot;#ffffff&quot;&gt;Option B (S3/SQS)&lt;/font&gt;&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="890" y="852" width="200" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="cost_h5" value="&lt;b&gt;&lt;font color=&quot;#ffffff&quot;&gt;Option C (AWS Batch)&lt;/font&gt;&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1120" y="852" width="200" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="cost_h6" value="&lt;b&gt;&lt;font color=&quot;#ffffff&quot;&gt;Notes&lt;/font&gt;&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1310" y="852" width="130" height="30" as="geometry"/>
        </mxCell>

        <!-- Row 1: S3 Copy -->
        <mxCell id="row1_bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#e0e0e0;" vertex="1" parent="1">
          <mxGeometry x="40" y="885" width="1400" height="35" as="geometry"/>
