{{ ansible_managed | comment }}
# Arkime 6 capture + viewer configuration. Keys verified at arkime.com/settings.
# Auth is header-primary (set by the Nginx LDAP proxy) with a digest emergency
# fallback. Fail-closed: requiredAuthHeader gates on AD group membership and
# userAuthIps restricts header trust to the loopback proxy only.
[default]
# ---- Elasticsearch / OpenSearch backend ----
elasticsearch={{ arkime_es_url }}
elasticsearchBasicAuth={{ (arkime_es_user ~ ':' ~ arkime_es_password) | b64encode }}
{% if arkime_es_scheme == 'https' %}
caTrustFile={{ arkime_container_catrust }}
{% endif %}

# ---- Shared secrets (must match across all viewers in the cluster) ----
passwordSecret={{ arkime_password_secret }}
serverSecret={{ arkime_server_secret }}
httpRealm={{ arkime_http_realm }}

# ---- Index rotation ----
rotateIndex={{ arkime_rotate_index }}

# ---- Authentication (header primary + digest fallback) ----
authMode={{ arkime_auth_mode }}
userNameHeader={{ arkime_username_header }}
requiredAuthHeader={{ arkime_required_auth_header }}
requiredAuthHeaderVal={{ arkime_user_ldap_groups | join(',') }}
# Trust the user header only from the loopback reverse proxy (fail-closed):
userAuthIps={{ arkime_user_auth_ips }}

# ---- Capture / write tuning ----
interface={{ capture_interfaces | join(';') }}
pcapDir={{ arkime_container_pcap }}
maxFileSizeG={{ arkime_max_file_size_g }}
freeSpaceG={{ arkime_free_space }}
packetThreads={{ packet_threads }}
pcapWriteSize={{ pcap_write_size }}
maxPacketsInQueue={{ max_packets_in_queue }}

# ---- Viewer ----
viewPort={{ arkime_viewer_port }}
viewHost={{ arkime_view_host }}

{% if arkime_auto_create_users | bool %}
# Auto-provision users on first header-authenticated request (Arkime >= 6.1.0).
# vals holds the (lowercased) request headers set by the Nginx LDAP proxy.
# SECURITY: every auto-created user gets ONLY the least-privilege default role.
# We do NOT auto-grant admin from the group header, because the proxy currently
# injects a STATIC allowed-groups value (it gates membership, not per-user group
# identity), so deriving admin from it would elevate everyone. Admins are granted
# out-of-band (arkime_add_user.sh ... --admin during init, or a userAdmin action).
# To enable automated group->role mapping, make the ldap-auth sidecar emit the
# user's real groups in a header and map vals['<that-header>'] here.
# headerAuthEnabled binds the account to the proxy header so it cannot bypass LDAP.
[user-auto-create]
userId=vals['{{ arkime_username_header }}']
userName=vals['{{ arkime_username_header }}']
enabled=true
webEnabled=true
headerAuthEnabled=true
roles=['{{ arkime_default_role }}']
{% endif %}
