{{ ansible_managed | comment }}
# Environment for the caltechads/nginx-ldap-auth-service sidecar.
# Variable names are exact per the upstream configuration documentation.

# ---- Listener ----------------------------------------------------------------
# Bind loopback explicitly: with host networking the sidecar otherwise binds the
# container hostname (e.g. 127.0.2.1), which Nginx's 127.0.0.1 subrequest cannot reach.
HOST=127.0.0.1
PORT={{ ldap_auth_listen_port }}
# The sidecar binds loopback only; Nginx terminates TLS, so run it over HTTP.
INSECURE=True
COOKIE_NAME={{ ldap_auth_cookie_name }}

# ---- Session / CSRF secrets --------------------------------------------------
SECRET_KEY={{ ldap_auth_session_secret }}
CSRF_SECRET_KEY={{ ldap_auth_csrf_secret }}

# ---- LDAP / Active Directory connection --------------------------------------
LDAP_URI={{ ldap_url }}
LDAP_BASEDN={{ ldap_base_dn }}
LDAP_BINDDN={{ ldap_bind_dn }}
LDAP_PASSWORD={{ ldap_bind_password }}
LDAP_STARTTLS={{ 'True' if ldap_starttls | bool else 'False' }}

# ---- User search -------------------------------------------------------------
LDAP_USERNAME_ATTRIBUTE={{ ldap_username_attribute }}
LDAP_GET_USER_FILTER={{ ldap_user_filter }}

# ---- Authorization: must reference the {username} placeholder (sidecar requirement)
LDAP_AUTHORIZATION_FILTER={{ ldap_authorization_filter }}

# ---- LDAPS CA trust (only when actually using TLS) ---------------------------
# The sidecar validates that the named CA file exists, so only set it for
# ldaps:// or StartTLS. Plain ldap:// (lab) needs no CA.
{% if ldap_url.startswith('ldaps') or (ldap_starttls | bool) %}
LDAP_CA_CERT_DIR=/certs
LDAP_CA_CERT_NAME={{ ldap_ca_file | basename }}
{% endif %}
