{{ ansible_managed | comment }}
# SECURITY-CRITICAL server block.
# Nginx terminates TLS, runs an auth_request subrequest against the
# nginx-ldap-auth-service sidecar, and on success injects the trusted identity
# headers ({{ arkime_username_header }} / {{ arkime_required_auth_header }}) for
# the Arkime viewer. Every client-supplied identity/authz header is cleared so a
# client can never spoof authentication.

{% if nginx_redirect_http %}
server {
    listen 80;
    listen [::]:80;
    server_name {{ nginx_server_name }};

    # Force everything to HTTPS.
    return 301 https://$host$request_uri;
}
{% endif %}

server {
    listen {{ nginx_listen_port }} ssl;
    listen [::]:{{ nginx_listen_port }} ssl;
    http2 on;
    server_name {{ nginx_server_name }};

    ssl_certificate     {{ nginx_tls_cert }};
    ssl_certificate_key {{ nginx_tls_key }};
    ssl_protocols       {{ nginx_ssl_protocols }};
    ssl_ciphers         {{ nginx_ssl_ciphers }};
    ssl_prefer_server_ciphers on;
    ssl_session_cache   shared:SSL:10m;
    ssl_session_timeout 1d;

{% if nginx_hsts_enabled %}
    add_header Strict-Transport-Security "max-age={{ nginx_hsts_max_age }}; includeSubDomains" always;
{% endif %}
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "SAMEORIGIN" always;

    client_max_body_size {{ nginx_client_max_body_size }};

    # ---- Internal auth subrequest to the ldap-auth sidecar -------------------
    # Returns 200 + X-Authenticated-User on success, 401 otherwise.
    location = /check-auth {
        internal;
        proxy_pass http://127.0.0.1:{{ ldap_auth_listen_port }}/check;
        proxy_pass_request_body off;
        proxy_set_header Content-Length "";
        proxy_set_header Host $host;
        proxy_set_header X-Cookie-Name "{{ ldap_auth_cookie_name }}";
        proxy_set_header X-Cookie-Domain "{{ ldap_auth_cookie_domain }}";
        proxy_set_header Cookie {{ ldap_auth_cookie_name }}=$cookie_{{ ldap_auth_cookie_name }};
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Proto-Scheme $scheme;
    }

    # ---- Login / logout views served by the ldap-auth sidecar ---------------
    # MUST send X-Cookie-Name/X-Cookie-Domain so the session cookie issued at
    # login matches what /check-auth validates.
    location /auth {
        proxy_pass http://127.0.0.1:{{ ldap_auth_listen_port }}/auth;
        proxy_set_header Host $host;
        proxy_set_header X-Cookie-Name "{{ ldap_auth_cookie_name }}";
        proxy_set_header X-Cookie-Domain "{{ ldap_auth_cookie_domain }}";
        proxy_set_header X-Auth-Realm "Restricted";
        proxy_set_header Cookie $http_cookie;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Proto-Scheme $scheme;
        proxy_set_header X-Host $host;
    }

    # ---- Protected Arkime viewer --------------------------------------------
    location / {
        auth_request /check-auth;

        # On a 401 from the subrequest, send the user to the login form.
        error_page 401 = @login;

        # Capture the identity the sidecar authoritatively returns.
        auth_request_set $auth_user $upstream_http_x_authenticated_user;

        # Trusted identity headers for Arkime header auth. The sidecar has
        # already verified group membership via LDAP_AUTHORIZATION_FILTER, so
        # the connecting user is authorized to receive the required-groups value.
        proxy_set_header {{ arkime_username_header }} $auth_user;
        proxy_set_header {{ arkime_required_auth_header }} "{{ arkime_user_ldap_groups | join(',') }}";

        # CRITICAL: clear every client-supplied identity/authz header. Nginx
        # forwards all client request headers by default (except Host and
        # Connection), so without these a client could spoof authentication.
        proxy_set_header X-Remote-User "";
        proxy_set_header X-Forwarded-User "";
        proxy_set_header X-Authenticated-User "";
        proxy_set_header Authorization "";

        proxy_pass http://127.0.0.1:{{ arkime_viewer_port }};

        # WebSocket / HTTP keepalive plumbing.
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        client_max_body_size {{ nginx_client_max_body_size }};
        proxy_read_timeout {{ nginx_proxy_read_timeout }};
        proxy_send_timeout {{ nginx_proxy_send_timeout }};
    }

    # ---- Login redirect target ----------------------------------------------
    location @login {
        return 302 /auth/login?service=$request_uri;
    }
}
