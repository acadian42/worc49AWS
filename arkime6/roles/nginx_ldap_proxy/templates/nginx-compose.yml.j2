{{ ansible_managed | comment }}
# fpc-nginx Compose project: front Nginx (TLS + auth_request) and the
# nginx-ldap-auth-service sidecar. Both use host networking so Nginx reaches the
# sidecar on 127.0.0.1:{{ ldap_auth_listen_port }}.
name: {{ nginx_compose_project }}
services:
  nginx:
    image: {{ nginx_image }}
    container_name: fpc-nginx
    network_mode: host
    restart: unless-stopped
    depends_on:
      - ldap-auth
    cap_drop:
      - ALL
    cap_add:
      # The official nginx entrypoint chowns its cache/temp dirs and drops the
      # worker to the nginx user, so it needs these beyond binding :443.
      - NET_BIND_SERVICE
      - CHOWN
      - SETUID
      - SETGID
      - DAC_OVERRIDE
    volumes:
      - {{ nginx_compose_dir }}/nginx.conf:/etc/nginx/nginx.conf:ro
      - {{ nginx_compose_dir }}/conf.d:/etc/nginx/conf.d:ro
      - {{ nginx_tls_cert }}:{{ nginx_tls_cert }}:ro
      - {{ nginx_tls_key }}:{{ nginx_tls_key }}:ro
      - {{ nginx_ca_cert_dest }}:{{ nginx_ca_cert_dest }}:ro
    logging:
      driver: "{{ docker_log_driver }}"
{% if docker_log_driver in ['json-file', 'local'] %}
      options:
        max-size: "{{ docker_log_options['max-size'] }}"
        max-file: "{{ docker_log_options['max-file'] }}"
{% endif %}

  ldap-auth:
    image: {{ ldap_auth_image }}
    container_name: fpc-ldap-auth
    # Bind loopback via the CLI flag — the sidecar ignores the HOST env and
    # otherwise listens on the container hostname (unreachable from 127.0.0.1).
    # --workers 1: the session store is in-memory, so multiple workers would not
    # share sessions (login on one worker, auth_request check on another -> 401).
    command: ["nginx-ldap-auth", "start", "--host", "127.0.0.1", "--port", "{{ ldap_auth_listen_port }}", "--workers", "1"]
    network_mode: host
    restart: unless-stopped
    env_file:
      - {{ nginx_compose_dir }}/ldap-auth.env
    volumes:
      - {{ ldap_ca_file | dirname }}:/certs:ro
    logging:
      driver: "{{ docker_log_driver }}"
{% if docker_log_driver in ['json-file', 'local'] %}
      options:
        max-size: "{{ docker_log_options['max-size'] }}"
        max-file: "{{ docker_log_options['max-file'] }}"
{% endif %}
