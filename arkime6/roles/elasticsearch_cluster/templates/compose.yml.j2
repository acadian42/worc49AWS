{{ ansible_managed | comment }}
# Per-host Elasticsearch Compose project ({{ elasticsearch_nodes_per_host }} nodes).
# Host networking + unique per-node ports. Heap via jvm.options.d (NOT ES_JAVA_OPTS).
name: {{ es_compose_project }}
services:
{% for n in es_node_defs %}
  {{ n.name }}:
    image: {{ es_image }}
    container_name: {{ n.name }}
    hostname: {{ n.name }}
    network_mode: host
    restart: unless-stopped
    stop_grace_period: 120s
    environment:
      ELASTIC_PASSWORD: "{{ es_bootstrap_password }}"
      bootstrap.memory_lock: "true"
{% for k, v in es_extra_env.items() %}
      {{ k }}: "{{ v }}"
{% endfor %}
    ulimits:
      memlock: -1
      nofile:
        soft: {{ es_ulimit_nofile }}
        hard: {{ es_ulimit_nofile }}
    mem_limit: {{ n.mem_limit_gib }}g
    volumes:
      - {{ es_data_path }}/{{ n.name }}:/usr/share/elasticsearch/data
      - {{ es_logs_path }}/{{ n.name }}:/usr/share/elasticsearch/logs
      - {{ es_config_path }}/{{ n.name }}/elasticsearch.yml:/usr/share/elasticsearch/config/elasticsearch.yml:ro
      - {{ es_config_path }}/{{ n.name }}/heap.options:/usr/share/elasticsearch/config/jvm.options.d/heap.options:ro
      - {{ es_config_path }}/{{ n.name }}/certs:/usr/share/elasticsearch/config/certs:ro
      - {{ es_snapshot_repo_path }}:/snapshots
    logging:
      driver: "{{ docker_log_driver }}"
{% if docker_log_driver in ['json-file', 'local'] %}
      options:
        max-size: "{{ docker_log_options['max-size'] }}"
        max-file: "{{ docker_log_options['max-file'] }}"
{% endif %}
{% endfor %}
