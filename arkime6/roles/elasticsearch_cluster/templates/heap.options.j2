{{ ansible_managed | comment }}
# Heap for {{ item.name }} — equal Xms/Xmx, <=50% container mem, <= compressed-oops ceiling.
-Xms{{ item.heap_gib }}g
-Xmx{{ item.heap_gib }}g
{% if es_gc_collector == 'g1' %}
-XX:+UseG1GC
{% endif %}
-XX:+AlwaysPreTouch
-XX:+HeapDumpOnOutOfMemoryError
-XX:HeapDumpPath={{ es_heap_dump_path }}
-Xlog:gc*,gc+age=trace,safepoint:file={{ es_gc_log_path }}:utctime,level,pid,tags:filecount=16,filesize=64m
