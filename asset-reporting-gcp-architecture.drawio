        <mxCell id="e32" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;strokeColor=#5F6368;strokeWidth=1.5;" edge="1" parent="1" source="ai-looker" target="con-audit">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ================= SCALE-OUT LEGEND ================= -->
        <mxCell id="legend" value="Scale-out considerations" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#1A73E8;strokeWidth=2;verticalAlign=top;fontStyle=1;fontSize=13;spacingTop=8;fontColor=#1A73E8" vertex="1" parent="1">
          <mxGeometry x="40" y="1040" width="1470" height="170" as="geometry" />
        </mxCell>
        <mxCell id="leg-1" value="➕ &lt;b&gt;New source&lt;/b&gt; → drop in a Cloud Run puller + Pub/Sub topic. Dataflow picks it up via a new subscription. Zero downstream changes." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="60" y="1075" width="700" height="22" as="geometry" />
        </mxCell>
        <mxCell id="leg-2" value="📊 &lt;b&gt;Volume&lt;/b&gt; → Pub/Sub &amp; Dataflow auto-scale. BigQuery slot-based scaling. Cloud Run 0 → N per service independently." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="60" y="1097" width="700" height="22" as="geometry" />
        </mxCell>
        <mxCell id="leg-3" value="🗄️ &lt;b&gt;Retention&lt;/b&gt; → BQ date-partitioning + clustering on (serial, tool). GCS lifecycle rules tier cold data to Nearline/Coldline/Archive." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="60" y="1119" width="700" height="22" as="geometry" />
        </mxCell>
        <mxCell id="leg-4" value="🌍 &lt;b&gt;HA / geography&lt;/b&gt; → Spanner multi-region for matched table. BQ multi-region dataset. Pub/Sub global topics optional." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="60" y="1141" width="700" height="22" as="geometry" />
        </mxCell>
        <mxCell id="leg-5" value="🔑 &lt;b&gt;Matching cost&lt;/b&gt; → serial indexed in Spanner for O(1) lookup. Heavy joins pushed down to BigQuery." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="60" y="1163" width="700" height="22" as="geometry" />
        </mxCell>
        <mxCell id="leg-6" value="🤖 &lt;b&gt;AI load&lt;/b&gt; → Vertex AI Agent Builder scales horizontally. API Gateway rate-limits per user. Cache common NL→SQL translations." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="780" y="1075" width="700" height="22" as="geometry" />
        </mxCell>
        <mxCell id="leg-7" value="📚 &lt;b&gt;Governance&lt;/b&gt; → Dataplex tracks schema, lineage, quality across sources. Essential as tool count grows." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="780" y="1097" width="700" height="22" as="geometry" />
        </mxCell>
        <mxCell id="leg-8" value="🔐 &lt;b&gt;Security&lt;/b&gt; → Cloud IAM for identity; VPC Service Controls around BQ/Spanner; Secret Manager for all tool creds." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="780" y="1119" width="700" height="22" as="geometry" />
        </mxCell>
        <mxCell id="leg-9" value="🔄 &lt;b&gt;Feedback loop&lt;/b&gt; → DQ alerts surface retired-but-live / live-but-retired drift, feeding back to CMDB owners (Dan's EUC point)." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="780" y="1141" width="700" height="22" as="geometry" />
        </mxCell>
        <mxCell id="leg-10" value="🔀 &lt;b&gt;Alt path&lt;/b&gt; → if Eric's data taxonomy already exists, attach Vertex AI Agent directly to his dataset (skip ingestion for phase 1)." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11;fontStyle=2" vertex="1" parent="1">
          <mxGeometry x="780" y="1163" width="700" height="22" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
