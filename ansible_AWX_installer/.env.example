# =============================================================================
# Optional environment overrides for the AWX installer.
#
# Copy to ".env" and edit. install.sh sources ".env" if present.
# NEVER put secrets in here (.env is gitignored, but secrets belong in .state/).
# =============================================================================

# --- VM sizing ---------------------------------------------------------------
# Defaults: 4 vCPUs, 8192 MB RAM. Override for bigger/smaller hosts.
#AWX_VM_CPUS=4
#AWX_VM_MEM=8192

# --- VM identity / box -------------------------------------------------------
#AWX_VM_NAME=ansible-awx-ubuntu24
#AWX_BOX=bento/ubuntu-24.04
#AWX_BOX_VERSION=202510.26.0

# --- Host port forwarding ----------------------------------------------------
# Guest NodePort is always 30080; this is the preferred HOST port (bound to
# 127.0.0.1). If busy, Vagrant auto-corrects and the real port is discovered
# at runtime via `vagrant port`.
#AWX_HOST_PORT=30080

# --- Version controls --------------------------------------------------------
# Set to 1 to allow resolve-versions.sh to bump pins when upstream moves.
# Default (unset/0): the pins in versions.yml are authoritative.
#AWX_ALLOW_VERSION_DRIFT=0

# Skip the live version-resolution network calls and use versions.yml as-is.
#AWX_OFFLINE=0
