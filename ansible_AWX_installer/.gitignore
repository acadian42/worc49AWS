# Project-local Python virtualenv
.venv/

# Vagrant runtime state (VM metadata, ssh keys, ids)
.vagrant/

# Generated secrets and host-side state (NEVER commit)
.state/

# Timestamped diagnostic/test artifacts
.artifacts/

# Cached downloads (boxes, debs, install scripts, resolved versions)
.cache/

# Generated Ansible inventory (transient SSH host/port/key)
inventory/generated/*
!inventory/generated/.gitkeep

# Generated static inventory for direct (host-local) installs (install-direct.sh)
inventory/local.ini

# Generated/rendered Kubernetes manifests that may embed secret references
k8s/awx/*-secret.yaml
k8s/awx/awx.rendered.yaml
k8s/operator/kustomization.rendered.yaml

# Local environment overrides
.env

# Downloaded artifacts
*.box
*.deb
*.tar
*.zst

# Editor / OS noise
*.swp
*~
.DS_Store
