# SMD — Claude Code on Vertex AI: pilot / CI environment template
# Mirrors managed-settings.json for environments where MDM policy is not present
# (build agents, containers). On managed workstations the MDM-deployed
# managed-settings.json is authoritative and overrides everything here.
#
# Prereqs (one-time, per developer):
#   gcloud auth login
#   gcloud auth application-default login
#   gcloud config set project <REPLACE-smd-ai-vertex-project>
# IAM: roles/aiplatform.user on the AI project. Model access must be enabled
# in Vertex Model Garden (24-48h lead time) and versions pinned before rollout.

# --- Routing: SMD Vertex only (CC-02) ---
export CLAUDE_CODE_USE_VERTEX=1
export ANTHROPIC_VERTEX_PROJECT_ID="REPLACE-smd-ai-vertex-project"
export CLOUD_ML_REGION="REPLACE-region-e.g-us-east5-or-global"
export ANTHROPIC_DEFAULT_SONNET_MODEL="REPLACE-pinned-vertex-model-id"

# --- Vendor telemetry off (CC-03). Note: the umbrella flag also disables the
# auto-updater; version rollout moves to internal distribution (CC-13). ---
export CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
export DISABLE_TELEMETRY=1
export DISABLE_ERROR_REPORTING=1
export DISABLE_BUG_COMMAND=1

# --- SMD observability: OpenTelemetry to our collector (CC-09).
# This is a SEPARATE system from Anthropic's telemetry above: it exports only
# to the endpoint below, never to Anthropic. Prompt content is redacted by
# default (length only). Do NOT set OTEL_LOG_USER_PROMPTS / OTEL_LOG_TOOL_DETAILS
# without a privacy review, restricted access, and short retention. ---
export CLAUDE_CODE_ENABLE_TELEMETRY=1
export OTEL_METRICS_EXPORTER=otlp
export OTEL_LOGS_EXPORTER=otlp
export OTEL_EXPORTER_OTLP_PROTOCOL=grpc
export OTEL_EXPORTER_OTLP_ENDPOINT="https://REPLACE-otel-collector.smd.internal:4317"
export OTEL_RESOURCE_ATTRIBUTES="team=smd-iq,deployment=interim-pilot"

# Verification (see templates/README.md for the full test plan):
#   claude          -> status line should show Vertex AI project/region
#   /permissions    -> managed deny rules visible and non-editable
