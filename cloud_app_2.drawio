        <mxCell id="c_cvpn_vpnu" value="HTTPS/443&#10;Management&#10;SSH/22 RDP/3389" style="endArrow=classic;html=1;rounded=0;strokeColor=#5B7FBD;strokeWidth=2;fontSize=10;fontStyle=1;startArrow=classic;exitX=1;exitY=0.5;entryX=0;entryY=0.4" edge="1" parent="1" source="cvpn" target="users_vpn">
