        <!-- ================= NOTES ================= -->

        <!-- AWS Services Cloud -->
        <mxCell id="aws_cloud" value="&lt;b&gt;AWS Services Used&lt;/b&gt;&#10;&#10;• EC2 (Web / Workers / Runners)&#10;• VPC&#10;• RDS (Postgres)&#10;• ElastiCache (Redis)&#10;• ELB / ALB&#10;• S3 / Glacier (optional)&#10;• Transit Gateway&#10;• Direct Connect&#10;• VPC Endpoint / PrivateLink&#10;• Bedrock (bedrock-agent-runtime)" style="shape=cloud;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=top;fontSize=10;align=left;spacingLeft=30" vertex="1" parent="1">
          <mxGeometry x="430" y="1000" width="330" height="200" as="geometry" />
