        <mxCell id="c_nc_slack" value="443&#10;(HTTPS)" style="endArrow=classic;html=1;rounded=0;strokeColor=#E8A33D;strokeWidth=2;fontSize=11;fontStyle=1;exitX=0.25;exitY=1;entryX=0.5;entryY=0" edge="1" parent="1" source="net_core" target="slack_grp">
