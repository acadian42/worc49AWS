        <mxCell id="c_nc_pypi" value="443 / 80&#10;(HTTPS / HTTP)" style="endArrow=classic;html=1;rounded=0;strokeColor=#E8A33D;strokeWidth=2;fontSize=11;fontStyle=1;exitX=0.75;exitY=1;entryX=0.5;entryY=0" edge="1" parent="1" source="net_core" target="pypi">
