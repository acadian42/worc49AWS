          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Net Core -> .NET Users Managed -->
        <mxCell id="c_nc_net" value="HTTPS/443" style="endArrow=classic;html=1;rounded=0;strokeColor=#E8A33D;strokeWidth=2;fontSize=11;fontStyle=1;startArrow=classic;exitX=1;exitY=0.5;entryX=0;entryY=0.5" edge="1" parent="1" source="net_core" target="users_net">
