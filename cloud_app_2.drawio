        <mxCell id="c_f5_ext" value="HTTPS/443" style="endArrow=classic;html=1;rounded=0;strokeColor=#E8A33D;strokeWidth=2;fontSize=11;fontStyle=1;startArrow=classic;exitX=1;exitY=0.3;entryX=0;entryY=0.5" edge="1" parent="1" source="f5" target="users_ext">
