        <mxCell id="inherited_label" value="&lt;b&gt;ECM Inherited Services&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="80" y="975" width="320" height="20" as="geometry" />
        </mxCell>
        <mxCell id="inherited" value="&lt;b&gt;The ECM Tenant is utilizing the&#10;following items:&lt;/b&gt;&#10;&#10;• All logging going to SPLUNK&#10;• Leidos Corporate Managed/Patched&#10;   AWS AMI Images&#10;• Nessus Scanning&#10;• SAST (Checkmarx)&#10;• DAST Scanning (Netsparker)&#10;• SCCM Patch Management&#10;• CMDB&#10;• Leidos Corporate Active Directory&#10;• CyberArk Privileged Credential&#10;   Storage&#10;• CloudStrike AV" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;verticalAlign=top;align=left;fontSize=10;spacingLeft=6" vertex="1" parent="1">
          <mxGeometry x="80" y="1000" width="320" height="220" as="geometry" />
